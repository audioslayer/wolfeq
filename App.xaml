<Application x:Class="WolfEQ.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <Color x:Key="WolfBg">#0F0F0F</Color>
        <Color x:Key="WolfShell">#141414</Color>
        <Color x:Key="WolfPanel">#1C1C1C</Color>
        <Color x:Key="WolfPanel2">#242424</Color>
        <Color x:Key="WolfLine">#2A2A2A</Color>
        <Color x:Key="WolfLineSoft">#363636</Color>
        <Color x:Key="WolfCyan">#06B6D4</Color>
        <Color x:Key="WolfCyanDim">#12323A</Color>
        <Color x:Key="WolfFiioRed">#C8102E</Color>
        <Color x:Key="WolfFiioRedDim">#331017</Color>
        <Color x:Key="WolfGreen">#00E676</Color>
        <Color x:Key="WolfWarning">#FFB800</Color>
        <Color x:Key="WolfDanger">#FF5555</Color>
        <Color x:Key="WolfText">#E8E8E8</Color>
        <Color x:Key="WolfMuted">#B0B0B0</Color>
        <Color x:Key="WolfDim">#7E7E7E</Color>
        <Color x:Key="WolfAccentHover">#1A00E676</Color>

        <SolidColorBrush x:Key="WolfBgBrush" Color="{StaticResource WolfBg}"/>
        <SolidColorBrush x:Key="WolfShellBrush" Color="{StaticResource WolfShell}"/>
        <SolidColorBrush x:Key="WolfPanelBrush" Color="{StaticResource WolfPanel}"/>
        <SolidColorBrush x:Key="WolfPanel2Brush" Color="{StaticResource WolfPanel2}"/>
        <SolidColorBrush x:Key="WolfLineBrush" Color="{StaticResource WolfLine}"/>
        <SolidColorBrush x:Key="WolfLineSoftBrush" Color="{StaticResource WolfLineSoft}"/>
        <SolidColorBrush x:Key="WolfCyanBrush" Color="{StaticResource WolfCyan}"/>
        <SolidColorBrush x:Key="WolfCyanDimBrush" Color="{StaticResource WolfCyanDim}"/>
        <SolidColorBrush x:Key="WolfFiioRedBrush" Color="{StaticResource WolfFiioRed}"/>
        <SolidColorBrush x:Key="WolfFiioRedDimBrush" Color="{StaticResource WolfFiioRedDim}"/>
        <SolidColorBrush x:Key="WolfGreenBrush" Color="{StaticResource WolfGreen}"/>
        <SolidColorBrush x:Key="WolfWarningBrush" Color="{StaticResource WolfWarning}"/>
        <SolidColorBrush x:Key="WolfDangerBrush" Color="{StaticResource WolfDanger}"/>
        <SolidColorBrush x:Key="WolfTextBrush" Color="{StaticResource WolfText}"/>
        <SolidColorBrush x:Key="WolfMutedBrush" Color="{StaticResource WolfMuted}"/>
        <SolidColorBrush x:Key="WolfDimBrush" Color="{StaticResource WolfDim}"/>
        <SolidColorBrush x:Key="WolfAccentHoverBrush" Color="{StaticResource WolfAccentHover}"/>

        <DropShadowEffect x:Key="WolfComboShadow"
                          Color="Black"
                          BlurRadius="18"
                          ShadowDepth="4"
                          Opacity="0.5"
                          Direction="270"/>

        <Style TargetType="Window">
            <Setter Property="FontFamily" Value="Bahnschrift"/>
            <Setter Property="Background" Value="{StaticResource WolfBgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource WolfTextBrush}"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource WolfTextBrush}"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource WolfTextBrush}"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource WolfMutedBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="DimText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource WolfDimBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="TinyLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{StaticResource WolfDimBrush}"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
        </Style>

        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource WolfTextBrush}"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource WolfPanelBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource WolfLineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <Style x:Key="InsetBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource WolfShellBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource WolfLineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12"/>
        </Style>

        <Style x:Key="BandCellBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource WolfShellBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource WolfLineSoftBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10"/>
        </Style>

        <Style x:Key="EqBandCardBorder" TargetType="Border" BasedOn="{StaticResource BandCellBorder}">
            <Setter Property="Width" Value="168"/>
            <Setter Property="MinHeight" Value="224"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Enabled}" Value="False">
                    <Setter Property="Background" Value="#090909"/>
                    <Setter Property="BorderBrush" Value="#222222"/>
                    <Setter Property="Opacity" Value="0.64"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BandPowerToggle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="Track"
                                Background="#0A0A0A"
                                BorderBrush="{StaticResource WolfLineSoftBrush}"
                                BorderThickness="1"
                                CornerRadius="5">
                            <Border x:Name="Thumb"
                                    Width="12"
                                    Height="12"
                                    Margin="4,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="{StaticResource WolfDimBrush}"
                                    CornerRadius="3"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{StaticResource WolfAccentHoverBrush}"/>
                                <Setter TargetName="Track" Property="BorderBrush" Value="{StaticResource WolfGreenBrush}"/>
                                <Setter TargetName="Thumb" Property="Background" Value="{StaticResource WolfGreenBrush}"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="BorderBrush" Value="{StaticResource WolfCyanBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SourceTileBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource WolfPanel2Brush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource WolfLineSoftBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource WolfPanel2Brush}"/>
            <Setter Property="Foreground" Value="{StaticResource WolfTextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource WolfLineSoftBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource WolfCyanBrush}"/>
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource WolfAccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource WolfCyanDimBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.42"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource WolfCyanDimBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource WolfCyanBrush}"/>
        </Style>

        <Style x:Key="WarningButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="BorderBrush" Value="{StaticResource WolfWarningBrush}"/>
        </Style>

        <Style x:Key="FiioButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource WolfAccentHoverBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource WolfGreenBrush}"/>
        </Style>

        <Style x:Key="QuietButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource WolfShellBrush}"/>
            <Setter Property="Padding" Value="9,5"/>
            <Setter Property="MinHeight" Value="28"/>
        </Style>

        <Style x:Key="MacWindowChromeButton" TargetType="Button">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Margin" Value="0,0,2,0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderBrush" Value="#66000000"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="Transparent">
                            <Ellipse x:Name="Circle"
                                     Width="14"
                                     Height="14"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Fill="{TemplateBinding Background}"
                                     Stroke="{TemplateBinding BorderBrush}"
                                     StrokeThickness="0.8"/>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="False"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Circle" Property="Stroke" Value="#55000000"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Circle" Property="Opacity" Value="0.72"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#5A1818"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MacWindowCloseButton" TargetType="Button" BasedOn="{StaticResource MacWindowChromeButton}">
            <Setter Property="Background" Value="#FF5F57"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style x:Key="MacWindowMinimizeButton" TargetType="Button" BasedOn="{StaticResource MacWindowChromeButton}">
            <Setter Property="Background" Value="#FFBD2E"/>
        </Style>

        <Style x:Key="MacWindowMaximizeButton" TargetType="Button" BasedOn="{StaticResource MacWindowChromeButton}">
            <Setter Property="Background" Value="#28C840"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource WolfPanel2Brush}"/>
            <Setter Property="Foreground" Value="{StaticResource WolfTextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource WolfLineSoftBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="{StaticResource WolfCyanBrush}"/>
            <Setter Property="Padding" Value="9,6"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="BandValueTextBox" TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource WolfTextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource WolfLineSoftBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="CaretBrush" Value="{DynamicResource WolfCyanBrush}"/>
            <Setter Property="Padding" Value="2,0"/>
            <Setter Property="MinHeight" Value="18"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <ControlTemplate x:Key="DarkComboToggle" TargetType="{x:Type ToggleButton}">
            <Border x:Name="Border"
                    CornerRadius="6"
                    Background="{StaticResource WolfPanel2Brush}"
                    BorderBrush="{StaticResource WolfLineSoftBrush}"
                    BorderThickness="1.5"
                    Padding="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="32"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="1"
                            BorderBrush="{StaticResource WolfLineBrush}"
                            BorderThickness="1,0,0,0">
                        <Path x:Name="Arrow"
                              Data="M 0,0 L 5,5 L 10,0"
                              Stroke="{StaticResource WolfTextBrush}"
                              StrokeThickness="1.5"
                              Fill="Transparent"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource WolfGreenBrush}"/>
                    <Setter TargetName="Border" Property="Background" Value="{StaticResource WolfPanelBrush}"/>
                    <Setter TargetName="Arrow" Property="Stroke" Value="{StaticResource WolfGreenBrush}"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource WolfGreenBrush}"/>
                    <Setter TargetName="Arrow" Property="Stroke" Value="{StaticResource WolfGreenBrush}"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="HoverComboBox" TargetType="{x:Type ComboBox}">
            <Setter Property="Foreground" Value="{StaticResource WolfTextBrush}"/>
            <Setter Property="Background" Value="{StaticResource WolfPanel2Brush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource WolfLineSoftBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Template="{StaticResource DarkComboToggle}"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"/>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              Margin="10,6,28,6"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   StaysOpen="False"
                                   PopupAnimation="Slide">
                                <Border x:Name="DropDownBorder"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        CornerRadius="6"
                                        Background="{StaticResource WolfShellBrush}"
                                        BorderBrush="{StaticResource WolfLineSoftBrush}"
                                        BorderThickness="1"
                                        Margin="0,2,0,0"
                                        Effect="{StaticResource WolfComboShadow}"
                                        SnapsToDevicePixels="True">
                                    <ScrollViewer Margin="2,4,2,4" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ComboBox}" BasedOn="{StaticResource HoverComboBox}"/>

        <Style TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Foreground" Value="{StaticResource WolfTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="Bd"
                                CornerRadius="4"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                Margin="2,1">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource WolfLineBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource WolfLineBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource WolfGreenBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource WolfAccentHoverBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource WolfGreenBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="{StaticResource WolfCyanBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Foreground" Value="{StaticResource WolfCyanBrush}"/>
            <Setter Property="Background" Value="{StaticResource WolfPanel2Brush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource WolfLineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource WolfMutedBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource WolfShellBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource WolfTextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource WolfLineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
        </Style>

        <Style TargetType="{x:Type ListBoxItem}">
            <Setter Property="Foreground" Value="{StaticResource WolfTextBrush}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="Chrome"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="4">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource WolfPanelBrush}"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource WolfLineSoftBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource WolfAccentHoverBrush}"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource WolfGreenBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource WolfGreenBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type Expander}">
            <Setter Property="Foreground" Value="{StaticResource WolfMutedBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Expander}">
                        <StackPanel>
                            <ToggleButton x:Name="HeaderSite"
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="Transparent"
                                          BorderBrush="Transparent"
                                          Foreground="{TemplateBinding Foreground}"
                                          Padding="0"
                                          Margin="0"
                                          HorizontalContentAlignment="Left">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border x:Name="HeaderChrome"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                BorderThickness="1"
                                                CornerRadius="5"
                                                Padding="4,3">
                                            <DockPanel>
                                                <Path x:Name="Arrow"
                                                      Data="M 0,0 L 4,4 L 8,0"
                                                      Stroke="{TemplateBinding Foreground}"
                                                      StrokeThickness="1.6"
                                                      Fill="Transparent"
                                                      Width="8"
                                                      Height="6"
                                                      Stretch="Uniform"
                                                      Margin="0,0,7,0"
                                                      VerticalAlignment="Center"/>
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </DockPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="HeaderChrome" Property="Background" Value="{StaticResource WolfPanelBrush}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource WolfGreenBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Arrow" Property="Data" Value="M 0,0 L 4,4 L 8,0"/>
                                                <Setter Property="Foreground" Value="{DynamicResource WolfCyanBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <ContentPresenter ContentSource="Header"/>
                            </ToggleButton>
                            <ContentPresenter x:Name="ExpandSite"
                                              Visibility="Collapsed"
                                              ContentSource="Content"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource WolfShellBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource WolfTextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource WolfLineBrush}"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource WolfLineBrush}"/>
            <Setter Property="RowBackground" Value="#161616"/>
            <Setter Property="AlternatingRowBackground" Value="#1A1A1A"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource WolfPanel2Brush}"/>
            <Setter Property="Foreground" Value="{StaticResource WolfMutedBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource WolfLineBrush}"/>
            <Setter Property="Padding" Value="8,7"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="MinHeight" Value="36"/>
        </Style>

        <Style x:Key="WolfScrollThumb" TargetType="{x:Type Thumb}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="ThumbChrome"
                                Background="{StaticResource WolfCyanDimBrush}"
                                CornerRadius="3"
                                Margin="1"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbChrome" Property="Background" Value="{StaticResource WolfCyanBrush}"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbChrome" Property="Background" Value="{StaticResource WolfGreenBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="8"/>
                    <Setter Property="Height" Value="Auto"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ScrollBar}">
                                <Border Background="Transparent" CornerRadius="4">
                                    <Track x:Name="PART_Track" IsDirectionReversed="True">
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource WolfScrollThumb}"/>
                                        </Track.Thumb>
                                    </Track>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="8"/>
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ScrollBar}">
                                <Border Background="Transparent" CornerRadius="4">
                                    <Track x:Name="PART_Track">
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource WolfScrollThumb}"/>
                                        </Track.Thumb>
                                    </Track>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type ScrollViewer}">
            <Setter Property="PanningMode" Value="Both"/>
        </Style>

        <Style x:Key="SidebarTabControl" TargetType="{x:Type TabControl}">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="{StaticResource WolfShellBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabControl}">
                        <Grid Background="{TemplateBinding Background}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="96"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="{StaticResource WolfBgBrush}"
                                    BorderBrush="{StaticResource WolfLineBrush}"
                                    BorderThickness="0,0,1,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="72"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0"
                                            Height="1"
                                            VerticalAlignment="Bottom"
                                            Margin="18,0,18,0"
                                            Background="Transparent"/>

                                    <TabPanel x:Name="HeaderPanel"
                                              Grid.Row="1"
                                              IsItemsHost="True"
                                              KeyboardNavigation.TabIndex="1"
                                              Background="Transparent"/>

                                    <Border Grid.Row="2"
                                            Height="1"
                                            VerticalAlignment="Top"
                                            Margin="14,0,14,0"
                                            Background="{StaticResource WolfLineBrush}"/>
                                </Grid>
                            </Border>

                            <Border Grid.Column="1" Background="{StaticResource WolfShellBrush}">
                                <ContentPresenter x:Name="PART_SelectedContentHost"
                                                  ContentSource="SelectedContent"
                                                  Margin="0"
                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarTabItem" TargetType="{x:Type TabItem}">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Foreground" Value="{StaticResource WolfMutedBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border x:Name="Chrome"
                                Width="64"
                                Height="64"
                                Margin="16,4"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource WolfGreenBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource WolfCyanBrush}"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="HiddenRail">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="Chrome" Property="Width" Value="0"/>
                                <Setter TargetName="Chrome" Property="Height" Value="0"/>
                                <Setter TargetName="Chrome" Property="Margin" Value="0"/>
                                <Setter TargetName="Chrome" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
