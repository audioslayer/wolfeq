<UserControl x:Class="WolfEQ.Views.SettingsPopover"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:WolfEQ"
             xmlns:controls="clr-namespace:WolfEQ.Controls"
             mc:Ignorable="d"
             d:DesignWidth="440"
             d:DesignHeight="820"
             Width="440"
             Foreground="{StaticResource WolfTextBrush}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <!-- Copied from MainWindow resources; views keep their own converter copies. -->
        <local:ReferenceEqualsMultiConverter x:Key="ReferenceEqualsMultiConverter"/>
    </UserControl.Resources>

    <Border Style="{StaticResource PanelBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header: title + close -->
            <DockPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="Settings"
                           Style="{StaticResource SectionTitle}"
                           DockPanel.Dock="Left"
                           Margin="0"
                           VerticalAlignment="Center"/>
                <Button x:Name="CloseButton"
                        DockPanel.Dock="Right"
                        Content="✕"
                        Style="{StaticResource QuietButton}"
                        Padding="8,3"
                        Margin="10,0,0,0"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right"
                        ToolTip="Close settings"
                        Click="CloseButton_Click"/>
            </DockPanel>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- 1. Theme: accent color swatches -->
                    <Expander Header="Theme"
                              Foreground="{StaticResource WolfMutedBrush}"
                              Margin="0,0,0,10">
                        <StackPanel Margin="0,10,0,0">
                            <TextBlock Text="Color"
                                       Style="{StaticResource TinyLabel}"
                                       Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding AccentColorOptions}" Margin="0,0,0,12">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Click="AccentColorSwatch_Click"
                                                Width="44"
                                                Height="44"
                                                Margin="0,0,8,8"
                                                Padding="0"
                                                Cursor="Hand"
                                                ToolTip="{Binding Name}"
                                                Background="Transparent"
                                                BorderBrush="Transparent">
                                            <Button.Template>
                                                <ControlTemplate TargetType="{x:Type Button}">
                                                    <Grid Width="44" Height="44">
                                                        <Border x:Name="SelectionRing"
                                                                Width="42"
                                                                Height="42"
                                                                CornerRadius="21"
                                                                BorderBrush="Transparent"
                                                                BorderThickness="0"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                                        <Border x:Name="Dot"
                                                                Width="34"
                                                                Height="34"
                                                                CornerRadius="17"
                                                                Background="{Binding Brush}"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Dot" Property="Opacity" Value="0.82"/>
                                                        </Trigger>
                                                        <DataTrigger Value="True">
                                                            <DataTrigger.Binding>
                                                                <MultiBinding Converter="{StaticResource ReferenceEqualsMultiConverter}">
                                                                    <Binding/>
                                                                    <Binding Path="DataContext.SelectedAccentColorOption"
                                                                             RelativeSource="{RelativeSource AncestorType={x:Type UserControl}}"/>
                                                                </MultiBinding>
                                                            </DataTrigger.Binding>
                                                            <Setter TargetName="SelectionRing" Property="BorderBrush" Value="{StaticResource WolfTextBrush}"/>
                                                            <Setter TargetName="SelectionRing" Property="BorderThickness" Value="2"/>
                                                        </DataTrigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Expander>

                    <!-- 2. Device: profile selection + detection (expanded by default) -->
                    <Expander Header="Device"
                              IsExpanded="True"
                              Foreground="{StaticResource WolfMutedBrush}"
                              Margin="0,0,0,10">
                        <StackPanel Margin="0,10,0,0">
                            <DockPanel Margin="0,0,0,10">
                                <Button Content="Detect"
                                        Command="{Binding ConnectCommand}"
                                        Style="{StaticResource QuietButton}"
                                        DockPanel.Dock="Right"
                                        HorizontalAlignment="Right"/>
                                <TextBlock Text="{Binding ConnectionText}"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </DockPanel>

                            <Border Style="{StaticResource SourceTileBorder}" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="Device profile" Style="{StaticResource TinyLabel}" Margin="0,0,0,6"/>
                                    <ComboBox ItemsSource="{Binding DeviceProfiles}"
                                              SelectedItem="{Binding SelectedDeviceProfile}"
                                              DisplayMemberPath="DisplayLabel"
                                              MinWidth="260"/>
                                    <TextBlock Text="{Binding DeviceSelectionStatus}"
                                               Style="{StaticResource DimText}"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0"/>
                                    <TextBlock Text="{Binding DeviceProfileCapabilityText}"
                                               Style="{StaticResource DimText}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Expander>

                    <!-- 3. Input: device input source -->
                    <Expander Header="Input"
                              Foreground="{StaticResource WolfMutedBrush}"
                              Margin="0,0,0,10"
                              IsEnabled="{Binding SelectedDeviceSupportsBleInput}">
                        <StackPanel Margin="0,10,0,0">
                            <DockPanel Margin="0,0,0,10" LastChildFill="False">
                                <Button Content="Refresh"
                                        Command="{Binding ReadInputSourceCommand}"
                                        Style="{StaticResource QuietButton}"
                                        DockPanel.Dock="Right"/>
                            </DockPanel>

                            <Border Style="{StaticResource SourceTileBorder}" Padding="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                        <TextBlock Text="Device input" Style="{StaticResource TinyLabel}" Margin="0,0,0,6"/>
                                        <ComboBox ItemsSource="{Binding DeviceInputSources}"
                                                  SelectedItem="{Binding SelectedDeviceInputSource}"
                                                  DisplayMemberPath="DisplayName"
                                                  MinWidth="200"/>
                                        <TextBlock Text="{Binding DeviceInputDisplay}"
                                                   Style="{StaticResource DimText}"
                                                   Margin="0,8,0,0"/>
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Content="Apply"
                                            Command="{Binding SetInputSourceCommand}"
                                            Style="{StaticResource AccentButton}"
                                            VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Expander>

                    <!-- 4. Device Controls: volume, limit, balance, gain/DRE, slot name -->
                    <Expander Header="Device Controls"
                              Foreground="{StaticResource WolfMutedBrush}"
                              Margin="0,0,0,10"
                              IsEnabled="{Binding SelectedDeviceSupportsBleDeviceControls}">
                        <StackPanel Margin="0,10,0,0">
                            <DockPanel Margin="0,0,0,10" LastChildFill="False">
                                <Button Content="Read"
                                        Command="{Binding ReadDeviceControlsCommand}"
                                        Style="{StaticResource QuietButton}"
                                        DockPanel.Dock="Right"/>
                            </DockPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Style="{StaticResource SourceTileBorder}" Margin="0,0,6,12" Padding="12">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,8">
                                            <TextBlock Text="Volume" Style="{StaticResource TinyLabel}" DockPanel.Dock="Left"/>
                                            <TextBlock Text="{Binding DeviceVolume, StringFormat={}{0:0}/99}"
                                                       Style="{StaticResource DimText}"
                                                       HorizontalAlignment="Right"/>
                                        </DockPanel>
                                        <controls:StyledSlider Minimum="0"
                                                               Maximum="99"
                                                               Value="{Binding DeviceVolume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               Step="1"
                                                               AccentColor="{DynamicResource WolfGreen}"
                                                               ShowLabel="False"/>
                                        <WrapPanel Margin="0,10,0,0">
                                            <Button Content="-"
                                                    Command="{Binding VolumeDownCommand}"
                                                    Style="{StaticResource QuietButton}"
                                                    MinWidth="44"/>
                                            <Button Content="+"
                                                    Command="{Binding VolumeUpCommand}"
                                                    Style="{StaticResource QuietButton}"
                                                    MinWidth="44"/>
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Style="{StaticResource SourceTileBorder}" Margin="6,0,0,12" Padding="12">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,8">
                                            <TextBlock Text="Volume Limit" Style="{StaticResource TinyLabel}" DockPanel.Dock="Left"/>
                                            <TextBlock Text="{Binding DeviceVolumeLimit, StringFormat={}{0:0}/99}"
                                                       Style="{StaticResource DimText}"
                                                       HorizontalAlignment="Right"/>
                                        </DockPanel>
                                        <controls:StyledSlider Minimum="0"
                                                               Maximum="99"
                                                               Value="{Binding DeviceVolumeLimit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               Step="1"
                                                               AccentColor="{DynamicResource WolfGreen}"
                                                               ShowLabel="False"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="1" Style="{StaticResource SourceTileBorder}" Margin="0,0,6,12" Padding="12">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,8">
                                            <TextBlock Text="Channel Balance" Style="{StaticResource TinyLabel}" DockPanel.Dock="Left"/>
                                            <TextBlock Text="{Binding DeviceChannelBalanceDisplay}"
                                                       Style="{StaticResource DimText}"
                                                       HorizontalAlignment="Right"/>
                                        </DockPanel>
                                        <controls:StyledSlider Minimum="-10"
                                                               Maximum="10"
                                                               Value="{Binding DeviceChannelBalance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               Step="1"
                                                               AccentColor="{DynamicResource WolfGreen}"
                                                               ShowLabel="False"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource SourceTileBorder}" Margin="6,0,0,12" Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="Gain / DRE" Style="{StaticResource TinyLabel}" Margin="0,0,0,10"/>
                                        <WrapPanel>
                                            <CheckBox Content="High Gain"
                                                      IsChecked="{Binding DeviceHighGain, Mode=TwoWay}"
                                                      Margin="0,0,18,8"/>
                                            <CheckBox Content="DRE"
                                                      IsChecked="{Binding DeviceDreEnabled, Mode=TwoWay}"
                                                      Margin="0,0,18,8"/>
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="2"
                                        Grid.ColumnSpan="2"
                                        Style="{StaticResource SourceTileBorder}"
                                        Margin="0,0,0,12"
                                        Padding="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Text="EQ Slot Name" Style="{StaticResource TinyLabel}" Margin="0,0,0,6"/>
                                            <TextBox Text="{Binding DeviceProfileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     MaxLength="8"
                                                     MinWidth="160"/>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="Rename Slot"
                                                Command="{Binding RenameUserSlotCommand}"
                                                Style="{StaticResource QuietButton}"
                                                VerticalAlignment="Bottom"/>
                                    </Grid>
                                </Border>

                                <TextBlock Grid.Row="3"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding DeviceControlsStatus}"
                                           Style="{StaticResource DimText}"
                                           TextWrapping="Wrap"/>
                            </Grid>
                        </StackPanel>
                    </Expander>

                    <!-- 5. Profile Lights: top / knob LED color, mode, power, scenes -->
                    <Expander Header="Profile Lights"
                              Foreground="{StaticResource WolfMutedBrush}"
                              Margin="0,0,0,10"
                              Visibility="{Binding SelectedDeviceSupportsBleLighting, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Margin="0,10,0,0">
                            <DockPanel Margin="0,0,0,10" LastChildFill="False">
                                <Button Content="Refresh"
                                        Command="{Binding ReadLightsCommand}"
                                        Style="{StaticResource QuietButton}"
                                        DockPanel.Dock="Right"/>
                            </DockPanel>

                            <StackPanel>
                                <Border Style="{StaticResource SourceTileBorder}" Margin="0,0,0,12">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,12">
                                            <StackPanel DockPanel.Dock="Left">
                                                <TextBlock Text="Top Light" FontWeight="SemiBold" FontSize="14"/>
                                                <TextBlock Text="{Binding TopLedSummary}"
                                                           Style="{StaticResource DimText}"
                                                           Margin="0,3,0,0"/>
                                            </StackPanel>
                                            <Button Click="TopLedPower_Click"
                                                    Style="{StaticResource QuietButton}"
                                                    DockPanel.Dock="Right"
                                                    HorizontalAlignment="Right">
                                                <TextBlock>
                                                    <TextBlock.Style>
                                                        <Style TargetType="{x:Type TextBlock}">
                                                            <Setter Property="Text" Value="Off"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding TopLedOn}" Value="False">
                                                                    <Setter Property="Text" Value="On"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Button>
                                        </DockPanel>

                                        <TextBlock Text="Color" Style="{StaticResource TinyLabel}" Margin="0,0,0,8"/>
                                        <ItemsControl ItemsSource="{Binding LedColorOptions}" Margin="0,0,0,12">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Click="TopLedColorSwatch_Click"
                                                            Width="34"
                                                            Height="34"
                                                            Margin="0,0,7,7"
                                                            Padding="0"
                                                            Cursor="Hand"
                                                            ToolTip="{Binding Name}"
                                                            Background="Transparent"
                                                            BorderBrush="Transparent">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="{x:Type Button}">
                                                                <Grid Width="34" Height="34">
                                                                    <Border x:Name="SelectionRing"
                                                                            Width="34"
                                                                            Height="34"
                                                                            CornerRadius="17"
                                                                            BorderBrush="Transparent"
                                                                            BorderThickness="0"
                                                                            HorizontalAlignment="Center"
                                                                            VerticalAlignment="Center"/>
                                                                    <Border x:Name="Dot"
                                                                            Width="24"
                                                                            Height="24"
                                                                            CornerRadius="12"
                                                                            Background="{Binding Brush}"
                                                                            HorizontalAlignment="Center"
                                                                            VerticalAlignment="Center"/>
                                                                </Grid>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="Dot" Property="Opacity" Value="0.82"/>
                                                                    </Trigger>
                                                                    <DataTrigger Value="True">
                                                                        <DataTrigger.Binding>
                                                                            <MultiBinding Converter="{StaticResource ReferenceEqualsMultiConverter}">
                                                                                <Binding/>
                                                                                <Binding Path="DataContext.SelectedTopLedColorOption"
                                                                                         RelativeSource="{RelativeSource AncestorType={x:Type UserControl}}"/>
                                                                            </MultiBinding>
                                                                        </DataTrigger.Binding>
                                                                        <Setter TargetName="SelectionRing" Property="BorderBrush" Value="{StaticResource WolfTextBrush}"/>
                                                                        <Setter TargetName="SelectionRing" Property="BorderThickness" Value="2"/>
                                                                    </DataTrigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <TextBlock Text="Mode" Style="{StaticResource TinyLabel}" Margin="0,0,0,8"/>
                                        <ItemsControl ItemsSource="{Binding LedModeOptions}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Content="{Binding Name}"
                                                            Click="TopLedMode_Click"
                                                            Style="{StaticResource QuietButton}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SourceTileBorder}">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,12">
                                            <StackPanel DockPanel.Dock="Left">
                                                <TextBlock Text="Knob Light" FontWeight="SemiBold" FontSize="14"/>
                                                <TextBlock Text="{Binding KnobLedSummary}"
                                                           Style="{StaticResource DimText}"
                                                           Margin="0,3,0,0"/>
                                            </StackPanel>
                                            <Button Click="KnobLedPower_Click"
                                                    Style="{StaticResource QuietButton}"
                                                    DockPanel.Dock="Right"
                                                    HorizontalAlignment="Right">
                                                <TextBlock>
                                                    <TextBlock.Style>
                                                        <Style TargetType="{x:Type TextBlock}">
                                                            <Setter Property="Text" Value="Off"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding KnobLedOn}" Value="False">
                                                                    <Setter Property="Text" Value="On"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Button>
                                        </DockPanel>

                                        <TextBlock Text="Color" Style="{StaticResource TinyLabel}" Margin="0,0,0,8"/>
                                        <ItemsControl ItemsSource="{Binding LedColorOptions}" Margin="0,0,0,12">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Click="KnobLedColorSwatch_Click"
                                                            Width="34"
                                                            Height="34"
                                                            Margin="0,0,7,7"
                                                            Padding="0"
                                                            Cursor="Hand"
                                                            ToolTip="{Binding Name}"
                                                            Background="Transparent"
                                                            BorderBrush="Transparent">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="{x:Type Button}">
                                                                <Grid Width="34" Height="34">
                                                                    <Border x:Name="SelectionRing"
                                                                            Width="34"
                                                                            Height="34"
                                                                            CornerRadius="17"
                                                                            BorderBrush="Transparent"
                                                                            BorderThickness="0"
                                                                            HorizontalAlignment="Center"
                                                                            VerticalAlignment="Center"/>
                                                                    <Border x:Name="Dot"
                                                                            Width="24"
                                                                            Height="24"
                                                                            CornerRadius="12"
                                                                            Background="{Binding Brush}"
                                                                            HorizontalAlignment="Center"
                                                                            VerticalAlignment="Center"/>
                                                                </Grid>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="Dot" Property="Opacity" Value="0.82"/>
                                                                    </Trigger>
                                                                    <DataTrigger Value="True">
                                                                        <DataTrigger.Binding>
                                                                            <MultiBinding Converter="{StaticResource ReferenceEqualsMultiConverter}">
                                                                                <Binding/>
                                                                                <Binding Path="DataContext.SelectedKnobLedColorOption"
                                                                                         RelativeSource="{RelativeSource AncestorType={x:Type UserControl}}"/>
                                                                            </MultiBinding>
                                                                        </DataTrigger.Binding>
                                                                        <Setter TargetName="SelectionRing" Property="BorderBrush" Value="{StaticResource WolfTextBrush}"/>
                                                                        <Setter TargetName="SelectionRing" Property="BorderThickness" Value="2"/>
                                                                    </DataTrigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <TextBlock Text="Mode" Style="{StaticResource TinyLabel}" Margin="0,0,0,8"/>
                                        <ItemsControl ItemsSource="{Binding LedModeOptions}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Content="{Binding Name}"
                                                            Click="KnobLedMode_Click"
                                                            Style="{StaticResource QuietButton}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <TextBlock Text="Presets"
                                       Style="{StaticResource TinyLabel}"
                                       Margin="0,14,0,8"/>
                            <ItemsControl ItemsSource="{Binding LedSceneOptions}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding Name}"
                                                Click="LedScene_Click"
                                                Style="{StaticResource QuietButton}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Expander>

                    <!-- 6. About: version, updates, releases, support -->
                    <Expander Header="About"
                              Foreground="{StaticResource WolfMutedBrush}">
                        <StackPanel Margin="0,10,0,0">
                            <DockPanel Margin="0,0,0,10" LastChildFill="False">
                                <Button Content="Releases"
                                        Command="{Binding OpenReleasesCommand}"
                                        Style="{StaticResource QuietButton}"
                                        DockPanel.Dock="Right"/>
                            </DockPanel>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="WolfEQ"
                                               FontSize="14"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding AppVersionText}"
                                               Style="{StaticResource DimText}"
                                               Margin="0,3,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="Check for Updates"
                                        Command="{Binding CheckForUpdatesCommand}"
                                        Style="{StaticResource AccentButton}"
                                        VerticalAlignment="Center"/>
                            </Grid>

                            <TextBlock Text="{Binding UpdateStatus}"
                                       Style="{StaticResource DimText}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12"/>

                            <Button Command="{Binding OpenBuyMeCoffeeCommand}"
                                    Style="{StaticResource QuietButton}"
                                    HorizontalAlignment="Left"
                                    ToolTip="buymeacoffee.com/audioslayer">
                                <StackPanel Orientation="Horizontal">
                                    <controls:PhosphorIcon IconName="Heart"
                                                           IconSize="15"
                                                           IconBrush="{DynamicResource WolfGreenBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,8,0"/>
                                    <TextBlock Text="Buy me a coffee"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
