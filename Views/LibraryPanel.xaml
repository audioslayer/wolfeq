<UserControl x:Class="WolfEQ.Views.LibraryPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:WolfEQ.Controls"
             xmlns:models="clr-namespace:WolfEQ.Models"
             mc:Ignorable="d"
             d:DesignWidth="420"
             d:DesignHeight="820"
             Width="420"
             Foreground="{StaticResource WolfTextBrush}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- Copied from MainWindow resources; views keep their own template copies. -->
        <DataTemplate x:Key="LibraryPresetListItemTemplate" DataType="{x:Type models:EqPreset}">
            <Grid Margin="4,3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="{Binding Name}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"/>
                <DockPanel Grid.Row="1" Margin="0,3,0,0">
                    <TextBlock Text="{Binding Category}"
                               Style="{StaticResource TinyLabel}"
                               DockPanel.Dock="Left"/>
                    <TextBlock Text="{Binding PreampDb, StringFormat={}{0:+0.0;-0.0;0.0} dB}"
                               Style="{StaticResource TinyLabel}"
                               HorizontalAlignment="Right"/>
                </DockPanel>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="OnlineProfileListItemTemplate">
            <Grid Margin="4,3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="{Binding Name}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Row="1"
                           Text="{Binding SourceSummary}"
                           Style="{StaticResource TinyLabel}"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,3,0,0"/>
            </Grid>
        </DataTemplate>

        <!-- My Library / Online source chip (mutually exclusive, chip-styled radios). -->
        <Style x:Key="SourceChip" TargetType="{x:Type RadioButton}">
            <Setter Property="Background" Value="{StaticResource WolfShellBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource WolfLineSoftBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource WolfMutedBrush}"/>
            <Setter Property="Padding" Value="14,5"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RadioButton}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource WolfCyanBrush}"/>
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource WolfAccentHoverBrush}"/>
                            </Trigger>
                            <!-- Checked wins over hover; declared last. -->
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource WolfGreenBrush}"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource WolfGreenBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource WolfGreenContrastBrush}"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Style="{StaticResource PanelBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 1. Header: title, preset count, close -->
            <DockPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="Library"
                           Style="{StaticResource SectionTitle}"
                           DockPanel.Dock="Left"
                           Margin="0"
                           VerticalAlignment="Center"/>
                <Button x:Name="CloseButton"
                        DockPanel.Dock="Right"
                        Content="✕"
                        Style="{StaticResource QuietButton}"
                        Padding="8,3"
                        Margin="10,0,0,0"
                        VerticalAlignment="Center"
                        ToolTip="Close the library"
                        Click="CloseButton_Click"/>
                <TextBlock Text="{Binding FilteredPresetCount, StringFormat={}{0} presets}"
                           Style="{StaticResource DimText}"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </DockPanel>

            <!-- 2. Source toggle -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                <RadioButton x:Name="MyLibrarySourceChip"
                             Content="My Library"
                             Style="{StaticResource SourceChip}"
                             GroupName="LibrarySource"
                             IsChecked="True"/>
                <RadioButton x:Name="OnlineSourceChip"
                             Content="Online"
                             Style="{StaticResource SourceChip}"
                             GroupName="LibrarySource"/>
            </StackPanel>

            <!-- 3. Search (one box per source; the inactive one is collapsed) -->
            <Grid Grid.Row="2"
                  Margin="0,0,0,10"
                  Visibility="{Binding IsChecked, ElementName=MyLibrarySourceChip, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBox Text="{Binding ProfileSearchText, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Filter saved presets"/>
            </Grid>
            <Grid Grid.Row="2"
                  Margin="0,0,0,10"
                  Visibility="{Binding IsChecked, ElementName=OnlineSourceChip, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding GitHubProfileSearchText, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,8,0"
                         ToolTip="Search AutoEQ and OPRA headphone presets"/>
                <Button Grid.Column="1"
                        Content="Search"
                        Command="{Binding SearchGitHubProfilesCommand}"
                        Style="{StaticResource FiioButton}"/>
            </Grid>

            <!-- 4. My Library source -->
            <Grid Grid.Row="3"
                  Visibility="{Binding IsChecked, ElementName=MyLibrarySourceChip, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ComboBox Grid.Row="0"
                          ItemsSource="{Binding ProfileCategories}"
                          SelectedItem="{Binding SelectedProfileCategory}"
                          Margin="0,0,0,10"
                          ToolTip="Show only one category"/>

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding FilteredPresets}"
                         SelectedItem="{Binding SelectedPreset}"
                         ItemTemplate="{StaticResource LibraryPresetListItemTemplate}"
                         MinHeight="120"/>

                <!-- Per-selection actions -->
                <UniformGrid Grid.Row="2" Columns="2" Margin="0,10,0,0">
                    <Button Content="Load into editor"
                            Command="{Binding LoadLibraryPresetIntoEditorCommand}"
                            Style="{StaticResource QuietButton}"
                            ToolTip="Open this preset in the editor"/>
                    <Button Content="Write to slot"
                            Command="{Binding WriteLibraryPresetToSlotCommand}"
                            Style="{StaticResource AccentButton}"
                            ToolTip="Write this preset to the device's target slot"/>
                </UniformGrid>

                <!-- Library housekeeping: local file only, never touches the device -->
                <WrapPanel Grid.Row="3" Margin="0,8,0,0">
                    <Button Content="New" Command="{Binding CreateFlatPresetCommand}"/>
                    <Button Content="Duplicate" Command="{Binding DuplicatePresetCommand}"/>
                    <Button Content="Delete"
                            Command="{Binding DeletePresetCommand}"
                            Style="{StaticResource WarningButton}"/>
                </WrapPanel>
            </Grid>

            <!-- 5. Online source -->
            <Grid Grid.Row="3"
                  Visibility="{Binding IsChecked, ElementName=OnlineSourceChip, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ListBox Grid.Row="0"
                         ItemsSource="{Binding GitHubProfiles}"
                         SelectedItem="{Binding SelectedGitHubProfile}"
                         ItemTemplate="{StaticResource OnlineProfileListItemTemplate}"
                         MinHeight="120"/>

                <TextBlock Grid.Row="1"
                           Text="{Binding GitHubProfileStatus}"
                           Style="{StaticResource DimText}"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,8,0,6"/>

                <controls:EqResponseGraphControl Grid.Row="2"
                                                 Bands="{Binding GitHubPreviewPreset.Bands}"
                                                 PreampDb="{Binding GitHubPreviewPreset.PreampDb, TargetNullValue=0}"
                                                 IsInteractive="False"
                                                 Height="140"
                                                 MinHeight="0"/>

                <UniformGrid Grid.Row="3" Columns="3" Margin="0,10,0,0">
                    <Button Content="Download"
                            Command="{Binding ImportGitHubProfileCommand}"
                            Style="{StaticResource QuietButton}"
                            ToolTip="Save this profile to My Library"/>
                    <Button Content="Load into editor"
                            Command="{Binding LoadOnlineProfileIntoEditorCommand}"
                            Style="{StaticResource QuietButton}"
                            ToolTip="Save this profile to My Library and open it in the editor"/>
                    <Button Content="Write to slot"
                            Command="{Binding WriteOnlineProfileToSlotCommand}"
                            Style="{StaticResource AccentButton}"
                            ToolTip="Save this profile to My Library and write it to the device's target slot"/>
                </UniformGrid>
            </Grid>

            <!-- 6. Single import/export cluster (R18) -->
            <Expander Grid.Row="4"
                      Header="Import / export"
                      Foreground="{StaticResource WolfMutedBrush}"
                      Margin="0,12,0,0">
                <WrapPanel Margin="0,8,0,0">
                    <Button Content="Import APO" Command="{Binding ImportApoFromFileCommand}"/>
                    <Button Content="Paste APO" Command="{Binding ImportApoFromClipboardCommand}"/>
                    <Button Content="Export APO" Command="{Binding ExportApoToFileCommand}"/>
                    <Button Content="Copy APO" Command="{Binding ExportApoToClipboardCommand}"/>
                    <Button Content="Import FiiO XML" Command="{Binding ImportFiioXmlFromFileCommand}"/>
                    <Button Content="Export FiiO XML" Command="{Binding ExportFiioXmlToFileCommand}"/>
                    <Button Content="Import JSON" Command="{Binding ImportJsonFromFileCommand}"/>
                    <Button Content="Export JSON" Command="{Binding ExportJsonToFileCommand}"/>
                    <Button Content="Import Library" Command="{Binding ImportLibraryJsonCommand}"/>
                    <Button Content="Export Library" Command="{Binding ExportLibraryJsonCommand}"/>
                    <Button Content="Copy Report" Command="{Binding CopyTuningReportCommand}"/>
                </WrapPanel>
            </Expander>
        </Grid>
    </Border>
</UserControl>
