<UserControl x:Class="WolfEQ.Views.EditorWorkspace"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:WolfEQ.Controls"
             xmlns:local="clr-namespace:WolfEQ"
             mc:Ignorable="d"
             d:DesignWidth="1100"
             d:DesignHeight="760"
             Foreground="{StaticResource WolfTextBrush}">
    <UserControl.Resources>
        <local:ReferenceEqualsMultiConverter x:Key="ReferenceEqualsMultiConverter"/>

        <Style x:Key="StripValueBox" TargetType="{x:Type TextBox}" BasedOn="{StaticResource BandValueTextBox}">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinHeight" Value="24"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 1. Interactive curve editor -->
        <Border Grid.Row="0"
                Style="{StaticResource PanelBorder}"
                Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Margin="0,0,0,8">
                    <TextBlock Text="EQ Curve"
                               Style="{StaticResource SectionTitle}"
                               DockPanel.Dock="Left"
                               Margin="0"/>
                    <TextBlock Text="20 Hz - 20 kHz"
                               Style="{StaticResource DimText}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>
                </DockPanel>

                <controls:EqResponseGraphControl x:Name="Graph"
                                                 Grid.Row="1"
                                                 MinHeight="220"
                                                 Bands="{Binding Bands}"
                                                 PreampDb="{Binding PreampDb}"
                                                 IsInteractive="True"
                                                 MinGainDb="{Binding SelectedDeviceProfile.MinGainDb}"
                                                 MaxGainDb="{Binding SelectedDeviceProfile.MaxGainDb}"
                                                 MinQ="{Binding SelectedDeviceProfile.MinQ}"
                                                 MaxQ="{Binding SelectedDeviceProfile.MaxQ}"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource PanelBorder}">
            <StackPanel>

                <!-- 2. Selected-band strip -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedBand, ElementName=Graph}"
                                                 Value="{x:Null}">
                                        <Setter Property="IsEnabled" Value="False"/>
                                        <Setter Property="Opacity" Value="0.45"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <TextBlock Text="{Binding SelectedBand.Number, ElementName=Graph, StringFormat=Band {0}}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource WolfGreenBrush}"
                                   VerticalAlignment="Center"
                                   MinWidth="62"
                                   Margin="0,0,12,0"/>

                        <TextBlock Text="Filter"
                                   Style="{StaticResource TinyLabel}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <ComboBox Width="150"
                                  ItemsSource="{Binding Source={x:Static controls:EqFilterTypeValues.All}}"
                                  SelectedItem="{Binding SelectedBand.FilterType, ElementName=Graph}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,18,0"/>

                        <TextBlock Text="Frequency"
                                   Style="{StaticResource TinyLabel}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBox x:Name="FrequencyBox"
                                 Width="56"
                                 Tag="Frequency"
                                 Style="{StaticResource StripValueBox}"
                                 Text="{Binding SelectedBand.FrequencyHz, ElementName=Graph, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                                 KeyDown="StripValueBox_KeyDown"
                                 LostFocus="StripValueBox_LostFocus"/>
                        <TextBlock Text="Hz"
                                   Style="{StaticResource ValueText}"
                                   VerticalAlignment="Center"
                                   Margin="4,0,18,0"/>

                        <TextBlock Text="Gain"
                                   Style="{StaticResource TinyLabel}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBox x:Name="GainBox"
                                 Width="46"
                                 Tag="Gain"
                                 Style="{StaticResource StripValueBox}"
                                 Text="{Binding SelectedBand.GainDb, ElementName=Graph, Mode=TwoWay, UpdateSourceTrigger=Explicit, StringFormat={}{0:F1}}"
                                 KeyDown="StripValueBox_KeyDown"
                                 LostFocus="StripValueBox_LostFocus"/>
                        <TextBlock Text="dB"
                                   Style="{StaticResource ValueText}"
                                   VerticalAlignment="Center"
                                   Margin="4,0,18,0"/>

                        <TextBlock Text="Q"
                                   Style="{StaticResource TinyLabel}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBox x:Name="QBox"
                                 Width="46"
                                 Tag="Q"
                                 Style="{StaticResource StripValueBox}"
                                 Text="{Binding SelectedBand.Q, ElementName=Graph, Mode=TwoWay, UpdateSourceTrigger=Explicit, StringFormat={}{0:F2}}"
                                 KeyDown="StripValueBox_KeyDown"
                                 LostFocus="StripValueBox_LostFocus"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Text="Click a dot on the curve to edit it"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource DimText}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedBand, ElementName=Graph}"
                                                 Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- 3. Band chips -->
                <ItemsControl ItemsSource="{Binding Bands}" Margin="0,0,0,12">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Click="BandChip_Click"
                                    Cursor="Hand"
                                    Focusable="False"
                                    Margin="0,0,6,6"
                                    Padding="0"
                                    MinHeight="0"
                                    ToolTip="Select this band on the curve.">
                                <Button.Template>
                                    <ControlTemplate TargetType="{x:Type Button}">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Button.Template>
                                <Border CornerRadius="6"
                                        BorderThickness="1"
                                        Padding="8,5">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource WolfPanel2Brush}"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource WolfLineSoftBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Enabled}" Value="False">
                                                    <Setter Property="Opacity" Value="0.45"/>
                                                </DataTrigger>
                                                <DataTrigger Value="True">
                                                    <DataTrigger.Binding>
                                                        <MultiBinding Converter="{StaticResource ReferenceEqualsMultiConverter}">
                                                            <Binding/>
                                                            <Binding ElementName="Graph" Path="SelectedBand"/>
                                                        </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource WolfGreenBrush}"/>
                                                    <Setter Property="Background" Value="{DynamicResource WolfAccentHoverBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <ToggleButton Width="14"
                                                      Height="14"
                                                      Margin="0,0,7,0"
                                                      VerticalAlignment="Center"
                                                      Cursor="Hand"
                                                      Focusable="False"
                                                      IsChecked="{Binding Enabled, Mode=TwoWay}"
                                                      ToolTip="Turn this band on or off.">
                                            <ToggleButton.Template>
                                                <ControlTemplate TargetType="{x:Type ToggleButton}">
                                                    <Grid Background="Transparent">
                                                        <Ellipse x:Name="Dot"
                                                                 Width="9"
                                                                 Height="9"
                                                                 Fill="Transparent"
                                                                 Stroke="{StaticResource WolfDimBrush}"
                                                                 StrokeThickness="1.25"/>
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="Dot" Property="Fill" Value="{DynamicResource WolfGreenBrush}"/>
                                                            <Setter TargetName="Dot" Property="Stroke" Value="{DynamicResource WolfGreenBrush}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Dot" Property="Stroke" Value="{DynamicResource WolfCyanBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </ToggleButton.Template>
                                        </ToggleButton>
                                        <TextBlock VerticalAlignment="Center" FontSize="12">
                                            <Run Text="{Binding Number, Mode=OneWay, StringFormat=B{0}}"/><Run Text=" · " Foreground="{StaticResource WolfDimBrush}"/><Run Text="{Binding FrequencyHz, Mode=OneWay, StringFormat={}{0} Hz}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 4. Preamp -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Preamp"
                               Style="{StaticResource TinyLabel}"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"/>
                    <controls:StyledSlider Grid.Column="1"
                                           Minimum="{Binding SelectedDeviceProfile.MinGainDb}"
                                           Maximum="{Binding SelectedDeviceProfile.MaxGainDb}"
                                           Value="{Binding PreampDb, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                           Step="0.5"
                                           AccentColor="{DynamicResource WolfGreen}"
                                           ShowLabel="False"
                                           VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2"
                               Text="{Binding PreampDb, StringFormat={}{0:F1} dB}"
                               Style="{StaticResource ValueText}"
                               VerticalAlignment="Center"
                               MinWidth="56"
                               TextAlignment="Right"
                               Margin="10,0"/>
                    <Button Grid.Column="3"
                            Content="Auto Headroom"
                            Command="{Binding ApplyAutoHeadroomCommand}"
                            Style="{StaticResource QuietButton}"
                            VerticalAlignment="Center"/>
                </Grid>

                <!-- 5. Headroom Guardian + 6. Tools -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource InsetBorder}"
                            Padding="10">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock Text="{Binding HeadroomGuardianTitle}"
                                           FontWeight="SemiBold"
                                           DockPanel.Dock="Left"/>
                                <TextBlock Text="{Binding TuningConfidenceText}"
                                           Style="{StaticResource TinyLabel}"
                                           HorizontalAlignment="Right"/>
                            </DockPanel>
                            <TextBlock Text="{Binding HeadroomGuardianText}"
                                       Style="{StaticResource MutedText}"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding DeviceFitReportText}"
                                       Style="{StaticResource DimText}"/>
                        </StackPanel>
                    </Border>

                    <Button Grid.Column="1"
                            x:Name="ToolsButton"
                            Content="Tools ▾"
                            Style="{StaticResource QuietButton}"
                            Click="ToolsButton_Click"
                            VerticalAlignment="Top"
                            Margin="12,0,0,0">
                        <Button.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                         Background="{StaticResource WolfPanelBrush}"
                                         BorderBrush="{StaticResource WolfLineSoftBrush}"
                                         Foreground="{StaticResource WolfTextBrush}">
                                <MenuItem Header="Sort by frequency"
                                          Command="{Binding SortBandsByFrequencyCommand}"/>
                                <MenuItem Header="Flatten all gains"
                                          Command="{Binding ZeroAllGainsCommand}"/>
                                <Separator/>
                                <MenuItem Header="Device Copy"
                                          Command="{Binding PrepareK13PresetCommand}"
                                          IsEnabled="{Binding SupportsK13PresetTools}"/>
                                <MenuItem Header="Smooth Copy"
                                          Command="{Binding SmoothK13PresetCommand}"
                                          IsEnabled="{Binding SupportsK13PresetTools}"/>
                                <Separator/>
                                <MenuItem Header="Copy tuning card"
                                          Command="{Binding CopyTuningCardCommand}"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
