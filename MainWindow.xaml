                                                        <Grid Width="44" Height="44">
                                                            <Border x:Name="SelectionRing"
                                                                    Width="42"
                                                                    Height="42"
                                                                    CornerRadius="21"
                                                                    BorderBrush="Transparent"
                                                                    BorderThickness="0"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"/>
                                                            <Border x:Name="Dot"
