<Window x:Class="WolfEQ.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:WolfEQ.Controls"
        xmlns:local="clr-namespace:WolfEQ"
        xmlns:models="clr-namespace:WolfEQ.Models"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="WolfEQ"
        Icon="Assets/icon/wolfeq.png"
        Width="1440"
        Height="900"
        MinWidth="1100"
        MinHeight="720"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WolfBgBrush}"
        Foreground="{StaticResource WolfTextBrush}"
        Loaded="MainWindow_Loaded">
    <Window.Resources>
        <local:ReferenceEqualsMultiConverter x:Key="ReferenceEqualsMultiConverter"/>
        <DataTemplate x:Key="EqPresetComboItemTemplate" DataType="{x:Type models:EqPreset}">
            <TextBlock Text="{Binding Name}"
                       TextTrimming="CharacterEllipsis"/>
        </DataTemplate>
    </Window.Resources>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource WolfBgBrush}"
                BorderBrush="{StaticResource WolfLineBrush}"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid Margin="14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Image Source="Assets/icon/wolfeq.png"
                           Width="42"
                           Height="42"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                    <TextBlock VerticalAlignment="Center">
                        <Run Text="WOLF"
                             FontFamily="Segoe UI Black"
                             FontSize="16"
                             FontWeight="Black"
                             Foreground="{DynamicResource WolfCyanBrush}"/>
                        <Run Text=" " FontSize="4"/>
                        <Run Text="EQ"
                             FontFamily="Segoe UI Black"
                             FontSize="16"
                             FontWeight="Black"
                             Foreground="{DynamicResource WolfCyanBrush}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="12,0,0,0">
                    <Ellipse Width="8"
                             Height="8"
                             Margin="0,0,8,0"
                             VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource WolfDimBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDeviceConnected}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource WolfGreenBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding ConnectionText}"
                               Foreground="{StaticResource WolfMutedBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding AppVersionText}"
                               Foreground="{StaticResource WolfDimBrush}"
                               FontSize="10"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0"/>
                    <Button Style="{StaticResource MacWindowMinimizeButton}"
                            Click="MinimizeWindow_Click"
                            Margin="0,0,2,0"
                            ToolTip="Minimize">
                        <Viewbox Width="8" Height="8">
                            <Canvas Width="10" Height="10">
                                <Path Data="M 2 5 L 8 5"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                      StrokeThickness="1.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                    <Button Style="{StaticResource MacWindowMaximizeButton}"
                            Click="MaximizeRestoreWindow_Click"
                            Margin="0,0,2,0"
                            ToolTip="Maximize / Restore">
                        <Viewbox Width="8" Height="8">
                            <Canvas Width="10" Height="10">
                                <Path Data="M 2 4 L 4 2 L 4 4 Z M 8 6 L 6 8 L 6 6 Z"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                    <Button Style="{StaticResource MacWindowCloseButton}"
                            Click="CloseWindow_Click"
                            Margin="0"
                            ToolTip="Close">
                        <Viewbox Width="8" Height="8">
                            <Canvas Width="10" Height="10">
                                <Path Data="M 2 2 L 8 8 M 8 2 L 2 8"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                      StrokeThickness="1.7"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl x:Name="MainTabs"
                    Grid.Row="1"
                    TabStripPlacement="Left"
                    Style="{StaticResource SidebarTabControl}"
                    ItemContainerStyle="{StaticResource SidebarTabItem}">
            <TabItem>
                <TabItem.Header>
                    <StackPanel>
                        <controls:PhosphorIcon IconName="SlidersHorizontal"
                                               IconSize="22"
                                               IconBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type TabItem}}}"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,3"/>
                        <TextBlock Text="Tune"
                                   FontSize="9"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type TabItem}}}"/>
                    </StackPanel>
                </TabItem.Header>

                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition x:Name="InspectorDrawerHandleColumn" Width="36"/>
                            <ColumnDefinition x:Name="InspectorDrawerColumn" Width="0"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <Border Style="{StaticResource PanelBorder}" Padding="0" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="280"/>
                                    </Grid.RowDefinitions>
                                    <DockPanel Margin="16,14,16,6">
                                        <TextBlock Text="Live EQ Response"
                                                   Style="{StaticResource SectionTitle}"
                                                   DockPanel.Dock="Left"
                                                   Margin="0"/>
                                        <TextBlock Text="20 Hz - 20 kHz"
                                                   Style="{StaticResource DimText}"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                    </DockPanel>
                                    <Grid Grid.Row="1" Margin="12,0,12,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="112"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Style="{StaticResource BandCellBorder}" Padding="8">
                                            <StackPanel HorizontalAlignment="Stretch">
                                                <TextBlock Text="Global"
                                                           Style="{StaticResource TinyLabel}"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding PreampDb, StringFormat={}{0:F1} dB}"
                                                           Style="{StaticResource ValueText}"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,4,0,6"/>
                                                <controls:StyledSlider Minimum="-24"
                                                                       Maximum="12"
                                                                       Value="{Binding PreampDb, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                       Step="0.5"
                                                                       AccentColor="{DynamicResource WolfGreen}"
                                                                       Orientation="Vertical"
                                                                       ShowLabel="False"
                                                                       Width="28"
                                                                       Height="196"
                                                                       HorizontalAlignment="Center"
                                                                       Margin="0,10,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <controls:EqResponseGraphControl Grid.Column="1"
                                                                          Bands="{Binding Bands}"
                                                                          PreampDb="{Binding PreampDb}"
                                                                          CompareBands="{Binding ComparePreset.Bands}"
                                                                          ComparePreampDb="{Binding ComparePreset.PreampDb, TargetNullValue=0}"
                                                                          Margin="12,0,0,0"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource PanelBorder}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <DockPanel Margin="0,0,0,12">
                                        <TextBlock Text="10-Band PEQ"
                                                   Style="{StaticResource SectionTitle}"
                                                   DockPanel.Dock="Left"
                                                   Margin="0"/>
                                        <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                                            <Button Content="All On" Command="{Binding EnableAllBandsCommand}"/>
                                            <Button Content="Bypass" Command="{Binding BypassAllBandsCommand}"/>
                                            <Button Content="Reset" Command="{Binding ZeroAllGainsCommand}"/>
                                        </WrapPanel>
                                    </DockPanel>

                                    <DockPanel Grid.Row="1" Margin="0,0,0,12">
                                        <TextBlock Text="{Binding PresetEditSummaryText}"
                                                   Style="{StaticResource MutedText}"
                                                   DockPanel.Dock="Left"
                                                   VerticalAlignment="Center"/>
                                        <Expander Header="More"
                                                  DockPanel.Dock="Right"
                                                  HorizontalAlignment="Right"
                                                  Foreground="{StaticResource WolfMutedBrush}">
                                            <WrapPanel Margin="0,8,0,0">
                                                <Button Content="Sort" Command="{Binding SortBandsByFrequencyCommand}"/>
                                                <Button Content="Make Device Copy" Command="{Binding PrepareK13PresetCommand}"/>
                                                <Button Content="Smooth Copy" Command="{Binding SmoothK13PresetCommand}"/>
                                            </WrapPanel>
                                        </Expander>
                                    </DockPanel>

                                    <ScrollViewer x:Name="EqBandScrollViewer"
                                                  Grid.Row="2"
                                                  HorizontalScrollBarVisibility="Auto"
                                                  VerticalScrollBarVisibility="Disabled"
                                                  Margin="0"
                                                  SizeChanged="EqBandScrollViewer_SizeChanged">
                                        <ItemsControl x:Name="EqBandItemsControl"
                                                      ItemsSource="{Binding Bands}"
                                                      Tag="158">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource EqBandCardBorder}"
                                                            Width="{Binding Tag, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                                            AllowDrop="True"
                                                            DragEnter="BandCard_DragEnter"
                                                            DragOver="BandCard_DragOver"
                                                            DragLeave="BandCard_DragLeave"
                                                            Drop="BandCard_Drop">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>

                                                            <DockPanel Grid.Row="0" Margin="0,0,0,8">
                                                                <ToggleButton IsChecked="{Binding Enabled}"
                                                                              Style="{StaticResource BandPowerToggle}"
                                                                              DockPanel.Dock="Right"
                                                                              ToolTip="Toggle this EQ band."/>
                                                                <Border Background="Transparent"
                                                                        Cursor="SizeAll"
                                                                        Padding="0,2,8,2"
                                                                        PreviewMouseLeftButtonDown="BandDragHandle_PreviewMouseLeftButtonDown"
                                                                        MouseMove="BandDragHandle_MouseMove"
                                                                        ToolTip="Drag to reorder this EQ band.">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="{Binding Number, StringFormat={}Band {0}}"
                                                                                   FontSize="15"
                                                                                   FontWeight="SemiBold">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Foreground" Value="{DynamicResource WolfGreenBrush}"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding Enabled}" Value="False">
                                                                                            <Setter Property="Foreground" Value="{StaticResource WolfDimBrush}"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                        <TextBlock Text="::"
                                                                                   Style="{StaticResource TinyLabel}"
                                                                                   Margin="7,2,0,0"/>
                                                                    </StackPanel>
                                                                </Border>
                                                            </DockPanel>

                                                            <StackPanel Grid.Row="1" Margin="0,0,0,10">
                                                                <TextBlock Text="Filter type" Style="{StaticResource TinyLabel}"/>
                                                                <ComboBox SelectedItem="{Binding FilterType}"
                                                                          ItemsSource="{Binding Source={x:Static controls:EqFilterTypeValues.All}}"
                                                                          Margin="0,4,0,0"/>
                                                            </StackPanel>

                                                            <StackPanel Grid.Row="2" Margin="0,0,0,10">
                                                                <DockPanel>
                                                                    <TextBlock Text="Gain" Style="{StaticResource TinyLabel}" DockPanel.Dock="Left"/>
                                                                    <StackPanel DockPanel.Dock="Right"
                                                                                Orientation="Horizontal"
                                                                                HorizontalAlignment="Right">
                                                                        <TextBox Text="{Binding GainDb, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=150, StringFormat={}{0:F1}}"
                                                                                 Style="{StaticResource BandValueTextBox}"
                                                                                 Width="42"
                                                                                 KeyDown="BandValueTextBox_KeyDown"/>
                                                                        <TextBlock Text=" dB"
                                                                                   Style="{StaticResource ValueText}"
                                                                                   VerticalAlignment="Center"/>
                                                                    </StackPanel>
                                                                </DockPanel>
                                                                <controls:StyledSlider Minimum="-12"
                                                                                       Maximum="12"
                                                                                       Value="{Binding GainDb, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                       Step="0.5"
                                                                                       AccentColor="{DynamicResource WolfGreen}"
                                                                                       ShowLabel="False"/>
                                                            </StackPanel>

                                                            <StackPanel Grid.Row="3" Margin="0,0,0,10">
                                                                <DockPanel>
                                                                    <TextBlock Text="Freq" Style="{StaticResource TinyLabel}" DockPanel.Dock="Left"/>
                                                                    <StackPanel DockPanel.Dock="Right"
                                                                                Orientation="Horizontal"
                                                                                HorizontalAlignment="Right">
                                                                        <TextBox Text="{Binding FrequencyHz, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=150}"
                                                                                 Style="{StaticResource BandValueTextBox}"
                                                                                 Width="52"
                                                                                 KeyDown="BandValueTextBox_KeyDown"/>
                                                                        <TextBlock Text=" Hz"
                                                                                   Style="{StaticResource ValueText}"
                                                                                   VerticalAlignment="Center"/>
                                                                    </StackPanel>
                                                                </DockPanel>
                                                                <controls:StyledSlider Minimum="20"
                                                                                       Maximum="20000"
                                                                                       Value="{Binding FrequencyHz, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                       Step="100"
                                                                                       AccentColor="{DynamicResource WolfGreen}"
                                                                                       ShowLabel="False"/>
                                                            </StackPanel>

                                                            <StackPanel Grid.Row="4">
                                                                <DockPanel>
                                                                    <TextBlock Text="Q" Style="{StaticResource TinyLabel}" DockPanel.Dock="Left"/>
                                                                    <TextBox Text="{Binding Q, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=150, StringFormat={}{0:F2}}"
                                                                             Style="{StaticResource BandValueTextBox}"
                                                                             Width="42"
                                                                             DockPanel.Dock="Right"
                                                                             KeyDown="BandValueTextBox_KeyDown"/>
                                                                </DockPanel>
                                                                <controls:StyledSlider Minimum="0.1"
                                                                                       Maximum="10"
                                                                                       Value="{Binding Q, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                       Step="0.1"
                                                                                       AccentColor="{DynamicResource WolfGreen}"
                                                                                       ShowLabel="False"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <Button x:Name="InspectorDrawerToggleButton"
                                Grid.Column="1"
                                Click="ToggleInspectorDrawer_Click"
                                Width="24"
                                Height="42"
                                VerticalAlignment="Top"
                                HorizontalAlignment="Right"
                                Margin="0,12,2,0"
                                Padding="0"
                                ToolTip="Show side panel"
                                Tag="Collapsed"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Foreground="{StaticResource WolfMutedBrush}"
                                AutomationProperties.Name="Show side panel">
                            <Button.Template>
                                <ControlTemplate TargetType="{x:Type Button}">
                                    <Grid Background="{TemplateBinding Background}">
                                        <Border x:Name="HandleChrome"
                                                Width="20"
                                                Height="40"
                                                CornerRadius="6"
                                                Background="{StaticResource WolfBgBrush}"
                                                BorderBrush="{StaticResource WolfLineSoftBrush}"
                                                BorderThickness="1"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Top">
                                            <Path x:Name="InspectorDrawerChevron"
                                                  Data="M 5 3 L 12 10 L 5 17"
                                                  Stroke="{TemplateBinding Foreground}"
                                                  StrokeThickness="1.6"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round"
                                                  Fill="Transparent"
                                                  Width="16"
                                                  Height="20"
                                                  Stretch="Uniform"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource WolfCyanBrush}"/>
                                            <Setter TargetName="HandleChrome" Property="Background" Value="{DynamicResource WolfAccentHoverBrush}"/>
                                            <Setter TargetName="HandleChrome" Property="BorderBrush" Value="{DynamicResource WolfCyanBrush}"/>
                                        </Trigger>
                                        <Trigger Property="Tag" Value="Collapsed">
                                            <Setter Property="Foreground" Value="{StaticResource WolfMutedBrush}"/>
                                            <Setter TargetName="HandleChrome" Property="Background" Value="{StaticResource WolfBgBrush}"/>
                                            <Setter TargetName="HandleChrome" Property="BorderBrush" Value="{StaticResource WolfLineSoftBrush}"/>
                                            <Setter TargetName="InspectorDrawerChevron" Property="Data" Value="M 5 3 L 12 10 L 5 17"/>
                                            <Setter Property="ToolTip" Value="Show side panel"/>
                                            <Setter Property="AutomationProperties.Name" Value="Show side panel"/>
                                        </Trigger>
                                        <Trigger Property="Tag" Value="Expanded">
                                            <Setter TargetName="HandleChrome" Property="Background" Value="{StaticResource WolfShellBrush}"/>
                                            <Setter TargetName="HandleChrome" Property="BorderBrush" Value="{StaticResource WolfLineSoftBrush}"/>
                                            <Setter TargetName="InspectorDrawerChevron" Property="Data" Value="M 12 3 L 5 10 L 12 17"/>
                                            <Setter Property="ToolTip" Value="Hide side panel"/>
                                            <Setter Property="AutomationProperties.Name" Value="Hide side panel"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <StackPanel x:Name="InspectorDrawerHost" Grid.Column="2" Visibility="Collapsed">
                            <Border Style="{StaticResource PanelBorder}" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="Preset" Style="{StaticResource SectionTitle}"/>
                                    <ComboBox ItemsSource="{Binding FilteredPresets}"
                                              SelectedItem="{Binding SelectedPreset}"
                                              ItemTemplate="{StaticResource EqPresetComboItemTemplate}"
                                              Margin="0,0,0,10"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <controls:StyledSlider Minimum="-24"
                                                               Maximum="12"
                                                               Value="{Binding PreampDb, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               Step="0.5"
                                                               AccentColor="{DynamicResource WolfGreen}"
                                                               ShowLabel="False"
                                                               Margin="0,0,12,0"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding PreampDb, StringFormat={}{0:F1} dB}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                    <Button Content="Auto Headroom"
                                            Command="{Binding ApplyAutoHeadroomCommand}"
                                            HorizontalAlignment="Left"
                                            Margin="0,10,0,0"/>
                                    <Border Style="{StaticResource SourceTileBorder}" Margin="0,12,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Live Sync"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding LiveDeviceEqSyncStatus}"
                                                       Style="{StaticResource DimText}"
                                                       Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource PanelBorder}" Margin="0,0,0,16">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,10">
                                        <TextBlock Text="Profile Lights"
                                                   Style="{StaticResource SectionTitle}"
                                                   DockPanel.Dock="Left"
                                                   Margin="0"/>
                                        <ComboBox ItemsSource="{Binding DeviceUserPresets}"
                                                  SelectedItem="{Binding SelectedDeviceUserPreset}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectionChanged="SlotLightingUserComboBox_SelectionChanged"
                                                  Width="168"
                                                  DockPanel.Dock="Right"/>
                                    </DockPanel>
                                    <TextBlock Text="{Binding SlotLightingSummary}"
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,12"/>

                                    <DockPanel Margin="0,0,0,8">
                                        <TextBlock Text="Top LED"
                                                   FontWeight="SemiBold"
                                                   DockPanel.Dock="Left"/>
                                        <Button Click="TopLedPower_Click"
                                                Style="{StaticResource QuietButton}"
                                                DockPanel.Dock="Right"
                                                HorizontalAlignment="Right"
                                                Margin="0">
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="{x:Type TextBlock}">
                                                        <Setter Property="Text" Value="Off"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding TopLedOn}" Value="False">
                                                                <Setter Property="Text" Value="On"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Button>
                                    </DockPanel>
                                    <ItemsControl ItemsSource="{Binding LedColorOptions}" Margin="0,0,0,8">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Click="TopLedColorSwatch_Click"
                                                        Width="28"
                                                        Height="28"
                                                        Margin="0,0,6,6"
                                                        Padding="0"
                                                        Cursor="Hand"
                                                        ToolTip="{Binding Name}"
                                                        Background="Transparent"
                                                        BorderBrush="Transparent">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="{x:Type Button}">
                                                            <Grid Width="28" Height="28">
                                                                <Border x:Name="Dot"
                                                                        Width="22"
                                                                        Height="22"
                                                                        CornerRadius="11"
                                                                        Background="{Binding Brush}"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"/>
                                                            </Grid>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Dot" Property="Opacity" Value="0.82"/>
                                                                </Trigger>
                                                                <DataTrigger Value="True">
                                                                    <DataTrigger.Binding>
                                                                        <MultiBinding Converter="{StaticResource ReferenceEqualsMultiConverter}">
                                                                            <Binding/>
                                                                            <Binding Path="DataContext.SelectedTopLedColorOption"
                                                                                     RelativeSource="{RelativeSource AncestorType={x:Type Window}}"/>
                                                                        </MultiBinding>
                                                                    </DataTrigger.Binding>
                                                                    <Setter TargetName="Dot" Property="Width" Value="26"/>
                                                                    <Setter TargetName="Dot" Property="Height" Value="26"/>
                                                                    <Setter TargetName="Dot" Property="CornerRadius" Value="13"/>
                                                                </DataTrigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <ItemsControl ItemsSource="{Binding LedModeOptions}" Margin="0,0,0,14">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Content="{Binding Name}"
                                                        Click="TopLedMode_Click"
                                                        Style="{StaticResource QuietButton}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <DockPanel Margin="0,0,0,8">
                                        <TextBlock Text="Knob LED"
                                                   FontWeight="SemiBold"
                                                   DockPanel.Dock="Left"/>
                                        <Button Click="KnobLedPower_Click"
                                                Style="{StaticResource QuietButton}"
                                                DockPanel.Dock="Right"
                                                HorizontalAlignment="Right"
                                                Margin="0">
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="{x:Type TextBlock}">
