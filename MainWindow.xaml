                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource PanelBorder}">
                                <StackPanel>
                                    <TextBlock Text="Device Fit" Style="{StaticResource SectionTitle}"/>
                                    <TextBlock Text="{Binding K13ReadinessText}" Style="{StaticResource MutedText}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding TuningConfidenceText}" Style="{StaticResource MutedText}" Margin="0,6,0,8"/>
                                    <ProgressBar Minimum="0"
                                                 Maximum="100"
                                                 Value="{Binding TuningConfidenceScore, Mode=OneWay}"
                                                 Height="8"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
