                                        <Button Content="Capture" Command="{Binding CaptureCompareCommand}"/>
                                        <Button Content="Swap" Command="{Binding SwapCompareCommand}"/>
                                        <Button Content="Clear" Command="{Binding ClearCompareCommand}"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel>
