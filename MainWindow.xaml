<Window x:Class="WolfEQ.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:WolfEQ.Controls"
        xmlns:views="clr-namespace:WolfEQ.Views"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="WolfEQ"
        Icon="Assets/icon/wolfeq.png"
        Width="1640"
        Height="900"
        MinWidth="1280"
        MinHeight="720"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WolfBgBrush}"
        Foreground="{StaticResource WolfTextBrush}"
        Loaded="MainWindow_Loaded">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom title bar: brand, connection state, Library / Settings, window buttons. -->
        <Border Grid.Row="0"
                Background="{StaticResource WolfBgBrush}"
                BorderBrush="{StaticResource WolfLineBrush}"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid Margin="14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Image Source="Assets/icon/wolfeq.png"
                           Width="42"
                           Height="42"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                    <TextBlock VerticalAlignment="Center">
                        <Run Text="WOLF"
                             FontFamily="Segoe UI Black"
                             FontSize="16"
                             FontWeight="Black"
                             Foreground="{DynamicResource WolfCyanBrush}"/>
                        <Run Text=" " FontSize="4"/>
                        <Run Text="EQ"
                             FontFamily="Segoe UI Black"
                             FontSize="16"
                             FontWeight="Black"
                             Foreground="{DynamicResource WolfCyanBrush}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="12,0,0,0">
                    <Ellipse Width="8"
                             Height="8"
                             Margin="0,0,8,0"
                             VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource WolfDimBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDeviceConnected}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource WolfGreenBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding ConnectionText}"
                               Foreground="{StaticResource WolfMutedBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding AppVersionText}"
                               Foreground="{StaticResource WolfDimBrush}"
                               FontSize="10"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0"/>
                    <Button x:Name="LibraryHeaderButton"
                            Style="{StaticResource QuietButton}"
                            Click="LibraryHeaderButton_Click"
                            Margin="0,0,6,0"
                            ToolTip="Open the preset library">
                        <StackPanel Orientation="Horizontal">
                            <controls:PhosphorIcon IconName="Folder"
                                                   IconSize="15"
                                                   IconBrush="{StaticResource WolfMutedBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,7,0"/>
                            <TextBlock Text="Library" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="SettingsHeaderButton"
                            Style="{StaticResource QuietButton}"
                            Click="SettingsHeaderButton_Click"
                            Margin="0,0,14,0"
                            ToolTip="Settings">
                        <controls:PhosphorIcon IconName="Gear"
                                               IconSize="16"
                                               IconBrush="{StaticResource WolfMutedBrush}"
                                               VerticalAlignment="Center"/>
                    </Button>
                    <Button Style="{StaticResource MacWindowMinimizeButton}"
                            Click="MinimizeWindow_Click"
                            Margin="0,0,2,0"
                            ToolTip="Minimize">
                        <Viewbox Width="8" Height="8">
                            <Canvas Width="10" Height="10">
                                <Path Data="M 2 5 L 8 5"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                      StrokeThickness="1.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                    <Button Style="{StaticResource MacWindowMaximizeButton}"
                            Click="MaximizeRestoreWindow_Click"
                            Margin="0,0,2,0"
                            ToolTip="Maximize / Restore">
                        <Viewbox Width="8" Height="8">
                            <Canvas Width="10" Height="10">
                                <Path Data="M 2 4 L 4 2 L 4 4 Z M 8 6 L 6 8 L 6 6 Z"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                    <Button Style="{StaticResource MacWindowCloseButton}"
                            Click="CloseWindow_Click"
                            Margin="0"
                            ToolTip="Close">
                        <Viewbox Width="8" Height="8">
                            <Canvas Width="10" Height="10">
                                <Path Data="M 2 2 L 8 8 M 8 2 L 2 8"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                      StrokeThickness="1.7"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Permanent device dock strip. -->
        <views:DeviceDock Grid.Row="1" Margin="16,12,16,0"/>

        <!-- The editor workspace fills the rest of the window. -->
        <views:EditorWorkspace Grid.Row="2" Margin="16,12,16,16"/>

        <!-- Overlay layer: right slide-overs for Library and Settings over a dim scrim. -->
        <Grid x:Name="OverlayLayer"
              Grid.Row="1"
              Grid.RowSpan="2"
              Panel.ZIndex="100"
              Visibility="Collapsed">
            <Border x:Name="OverlayDimmer"
                    Background="#99000000"
                    MouseLeftButtonDown="OverlayDimmer_MouseLeftButtonDown"/>
            <views:LibraryPanel x:Name="LibraryHost"
                                HorizontalAlignment="Right"
                                Margin="0,12,12,12"
                                Visibility="Collapsed">
                <views:LibraryPanel.RenderTransform>
                    <TranslateTransform X="452"/>
                </views:LibraryPanel.RenderTransform>
            </views:LibraryPanel>
            <views:SettingsPopover x:Name="SettingsHost"
                                   HorizontalAlignment="Right"
                                   Margin="0,12,12,12"
                                   Visibility="Collapsed">
                <views:SettingsPopover.RenderTransform>
                    <TranslateTransform X="472"/>
                </views:SettingsPopover.RenderTransform>
            </views:SettingsPopover>
        </Grid>
    </Grid>
</Window>
