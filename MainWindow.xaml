                                                <Button Content="Duplicate" Command="{Binding DuplicatePresetCommand}"/>
                                                <Button Content="Favorite" Command="{Binding ToggleFavoriteCommand}"/>
                                            </WrapPanel>
                                        </DockPanel>
                                        <Expander Header="More"
                                                  Margin="3,10,0,0"
