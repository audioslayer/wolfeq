                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Button>
                                            </DockPanel>

                                            <TextBlock Text="Color" Style="{StaticResource TinyLabel}" Margin="0,0,0,8"/>
                                            <ItemsControl ItemsSource="{Binding LedColorOptions}" Margin="0,0,0,12">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Click="TopLedColorSwatch_Click"
                                                                Width="34"
                                                                Height="34"
                                                                Margin="0,0,7,7"
                                                                Padding="0"
                                                                Cursor="Hand"
                                                                ToolTip="{Binding Name}"
                                                                Background="Transparent"
                                                                BorderBrush="Transparent">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="{x:Type Button}">
                                                                    <Grid Width="34" Height="34">
                                                                        <Border x:Name="SelectionRing"
                                                                                Width="34"
                                                                                Height="34"
                                                                                CornerRadius="17"
                                                                                BorderBrush="Transparent"
                                                                                BorderThickness="0"
                                                                                HorizontalAlignment="Center"
                                                                                VerticalAlignment="Center"/>
                                                                        <Border x:Name="Dot"
                                                                                Width="24"
                                                                                Height="24"
                                                                                CornerRadius="12"
                                                                                Background="{Binding Brush}"
                                                                                HorizontalAlignment="Center"
                                                                                VerticalAlignment="Center"/>
                                                                    </Grid>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="Dot" Property="Opacity" Value="0.82"/>
                                                                        </Trigger>
                                                                        <DataTrigger Value="True">
                                                                            <DataTrigger.Binding>
                                                                                <MultiBinding Converter="{StaticResource ReferenceEqualsMultiConverter}">
                                                                                    <Binding/>
                                                                                    <Binding Path="DataContext.SelectedTopLedColorOption"
                                                                                             RelativeSource="{RelativeSource AncestorType={x:Type Window}}"/>
                                                                                </MultiBinding>
                                                                            </DataTrigger.Binding>
                                                                            <Setter TargetName="SelectionRing" Property="BorderBrush" Value="{StaticResource WolfTextBrush}"/>
                                                                            <Setter TargetName="SelectionRing" Property="BorderThickness" Value="2"/>
                                                                        </DataTrigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <TextBlock Text="Mode" Style="{StaticResource TinyLabel}" Margin="0,0,0,8"/>
                                            <ItemsControl ItemsSource="{Binding LedModeOptions}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Content="{Binding Name}"
                                                                Click="TopLedMode_Click"
                                                                Style="{StaticResource QuietButton}"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource SourceTileBorder}">
                                        <StackPanel>
                                            <DockPanel Margin="0,0,0,12">
                                                <StackPanel DockPanel.Dock="Left">
                                                    <TextBlock Text="Knob Light" FontWeight="SemiBold" FontSize="14"/>
                                                    <TextBlock Text="{Binding KnobLedSummary}"
                                                               Style="{StaticResource DimText}"
                                                               Margin="0,3,0,0"/>
                                                </StackPanel>
                                                <Button Click="KnobLedPower_Click"
                                                        Style="{StaticResource QuietButton}"
                                                        DockPanel.Dock="Right"
                                                        HorizontalAlignment="Right">
                                                    <TextBlock>
                                                        <TextBlock.Style>
                                                            <Style TargetType="{x:Type TextBlock}">
                                                                <Setter Property="Text" Value="Off"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding KnobLedOn}" Value="False">
                                                                        <Setter Property="Text" Value="On"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Button>
                                            </DockPanel>

                                            <TextBlock Text="Color" Style="{StaticResource TinyLabel}" Margin="0,0,0,8"/>
                                            <ItemsControl ItemsSource="{Binding LedColorOptions}" Margin="0,0,0,12">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Click="KnobLedColorSwatch_Click"
                                                                Width="34"
                                                                Height="34"
                                                                Margin="0,0,7,7"
                                                                Padding="0"
                                                                Cursor="Hand"
                                                                ToolTip="{Binding Name}"
                                                                Background="Transparent"
                                                                BorderBrush="Transparent">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="{x:Type Button}">
                                                                    <Grid Width="34" Height="34">
                                                                        <Border x:Name="SelectionRing"
                                                                                Width="34"
                                                                                Height="34"
                                                                                CornerRadius="17"
                                                                                BorderBrush="Transparent"
                                                                                BorderThickness="0"
                                                                                HorizontalAlignment="Center"
                                                                                VerticalAlignment="Center"/>
                                                                        <Border x:Name="Dot"
                                                                                Width="24"
                                                                                Height="24"
                                                                                CornerRadius="12"
                                                                                Background="{Binding Brush}"
                                                                                HorizontalAlignment="Center"
                                                                                VerticalAlignment="Center"/>
                                                                    </Grid>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="Dot" Property="Opacity" Value="0.82"/>
                                                                        </Trigger>
                                                                        <DataTrigger Value="True">
                                                                            <DataTrigger.Binding>
                                                                                <MultiBinding Converter="{StaticResource ReferenceEqualsMultiConverter}">
                                                                                    <Binding/>
                                                                                    <Binding Path="DataContext.SelectedKnobLedColorOption"
                                                                                             RelativeSource="{RelativeSource AncestorType={x:Type Window}}"/>
                                                                                </MultiBinding>
                                                                            </DataTrigger.Binding>
                                                                            <Setter TargetName="SelectionRing" Property="BorderBrush" Value="{StaticResource WolfTextBrush}"/>
                                                                            <Setter TargetName="SelectionRing" Property="BorderThickness" Value="2"/>
                                                                        </DataTrigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <TextBlock Text="Mode" Style="{StaticResource TinyLabel}" Margin="0,0,0,8"/>
                                            <ItemsControl ItemsSource="{Binding LedModeOptions}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Content="{Binding Name}"
                                                                Click="KnobLedMode_Click"
                                                                Style="{StaticResource QuietButton}"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <TextBlock Text="Presets"
                                           Style="{StaticResource TinyLabel}"
                                           Margin="0,14,0,8"/>
                                <ItemsControl ItemsSource="{Binding LedSceneOptions}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding Name}"
                                                    Click="LedScene_Click"
                                                    Style="{StaticResource QuietButton}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="5" Style="{StaticResource PanelBorder}">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,14">
                                    <TextBlock Text="About"
                                               Style="{StaticResource SectionTitle}"
                                               DockPanel.Dock="Left"
                                               Margin="0"/>
                                    <Button Content="Releases"
                                            Command="{Binding OpenReleasesCommand}"
                                            Style="{StaticResource QuietButton}"
                                            DockPanel.Dock="Right"
                                            HorizontalAlignment="Right"/>
                                </DockPanel>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                        <TextBlock Text="WolfEQ"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding AppVersionText}"
                                                   Style="{StaticResource DimText}"
                                                   Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Content="Check for Updates"
                                            Command="{Binding CheckForUpdatesCommand}"
                                            Style="{StaticResource AccentButton}"
                                            VerticalAlignment="Center"/>
                                </Grid>

                                <TextBlock Text="{Binding UpdateStatus}"
                                           Style="{StaticResource DimText}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,12"/>

                                <Button Command="{Binding OpenBuyMeCoffeeCommand}"
                                        Style="{StaticResource QuietButton}"
                                        HorizontalAlignment="Left"
                                        ToolTip="buymeacoffee.com/audioslayer">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:PhosphorIcon IconName="Heart"
                                                               IconSize="15"
                                                               IconBrush="{DynamicResource WolfGreenBrush}"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,8,0"/>
                                        <TextBlock Text="Buy me a coffee"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Button x:Name="SidebarSettingsButton"
                Grid.Row="1"
                Width="64"
                Height="64"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Left"
                Margin="16,0,0,14"
                Panel.ZIndex="20"
                Click="SidebarSettingsButton_Click"
                ToolTip="Settings"
                Cursor="Hand"
                Background="Transparent"
                BorderBrush="Transparent"
                Foreground="{StaticResource WolfMutedBrush}">
            <Button.Template>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="0">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <controls:PhosphorIcon IconName="Gear"
                                                   IconSize="22"
                                                   IconBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,3"/>
                            <TextBlock Text="Settings"
                                       FontSize="9"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource WolfGreenBrush}"/>
                        </Trigger>
                        <DataTrigger Binding="{Binding ElementName=MainTabs, Path=SelectedItem.Tag}" Value="HiddenRail">
                            <Setter Property="Foreground" Value="{DynamicResource WolfCyanBrush}"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <Button x:Name="ProfileSwitcherButton"
                Grid.Row="1"
                Width="64"
                Height="64"
                VerticalAlignment="Top"
                HorizontalAlignment="Left"
                Margin="16,4,0,0"
                Click="ProfileSwitcherButton_Click"
                ToolTip="Switch EQ slot"
                Cursor="Hand"
                Background="Transparent"
                BorderBrush="Transparent"
                Padding="0">
            <Button.Template>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="0">
                        <Grid>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Grid Width="30" Height="24" HorizontalAlignment="Center">
                                <Border x:Name="ProfileBadge"
                                        Width="26"
                                        Height="24"
                                        CornerRadius="0"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        BorderThickness="0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Top">
                                    <controls:PhosphorIcon IconName="AppWindow"
                                                           IconSize="24"
                                                           IconBrush="{DynamicResource WolfCyanBrush}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                </Border>
                                <Border x:Name="ProfileCaretBadge"
                                        Width="18"
                                        Height="18"
                                        Visibility="Collapsed"
                                        CornerRadius="9"
                                        Background="{StaticResource WolfShellBrush}"
                                        BorderBrush="{StaticResource WolfLineSoftBrush}"
                                        BorderThickness="1"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom">
                                    <TextBlock Text="⌄"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource WolfMutedBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                        Margin="0,-2,0,0"/>
                                </Border>
                            </Grid>
                            <TextBlock Text="Slots"
                                       FontSize="9"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource WolfMutedBrush}"
                                       HorizontalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="72"
                                       Margin="0,3,0,0"/>
                            </StackPanel>
                            <Path x:Name="ProfileFlyoutChevron"
                                  Data="M 5 3 L 12 10 L 5 17"
                                  Stroke="{StaticResource WolfMutedBrush}"
                                  StrokeThickness="1.45"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Fill="Transparent"
                                  Width="12"
                                  Height="16"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Margin="0,0,2,0"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ProfileBadge" Property="Opacity" Value="0.82"/>
                            <Setter TargetName="ProfileFlyoutChevron" Property="Stroke" Value="{DynamicResource WolfGreenBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <Popup x:Name="UserProfileFlyout"
               Grid.Row="1"
               PlacementTarget="{Binding ElementName=ProfileSwitcherButton}"
               Placement="Right"
               AllowsTransparency="True"
               StaysOpen="False"
               PopupAnimation="Fade"
               HorizontalOffset="10"
               VerticalOffset="6">
            <Border Background="{StaticResource WolfShellBrush}"
                    BorderBrush="{StaticResource WolfLineSoftBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="8"
                    Width="236">
                <Border.Effect>
                    <DropShadowEffect Color="Black"
                                      BlurRadius="24"
                                      ShadowDepth="6"
                                      Opacity="0.55"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="EQ slots"
                               Style="{StaticResource TinyLabel}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource WolfMutedBrush}"
                               Margin="8,4,0,8"/>
                    <ItemsControl ItemsSource="{Binding DeviceUserPresets}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Click="UserProfileItem_Click"
                                        Cursor="Hand"
                                        HorizontalContentAlignment="Stretch"
                                        Padding="0"
                                        Margin="0,2"
                                        Background="Transparent"
                                        BorderBrush="Transparent">
                                    <Button.Template>
                                        <ControlTemplate TargetType="{x:Type Button}">
                                            <Border x:Name="Chrome"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="8,7">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Chrome" Property="Background" Value="{StaticResource WolfPanelBrush}"/>
                                                    <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource WolfLineSoftBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource WolfCyanDimBrush}"/>
                                                </Trigger>
                                                <DataTrigger Value="True">
                                                    <DataTrigger.Binding>
                                                        <MultiBinding Converter="{StaticResource ReferenceEqualsMultiConverter}">
                                                            <Binding/>
                                                            <Binding Path="DataContext.SelectedDeviceUserPreset"
                                                                     RelativeSource="{RelativeSource AncestorType={x:Type Window}}"/>
                                                        </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource WolfAccentHoverBrush}"/>
                                                    <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource WolfGreenBrush}"/>
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border x:Name="ActiveProfileStripe"
                                                Width="3"
                                                Height="28"
                                                CornerRadius="2"
                                                Background="{DynamicResource WolfGreenBrush}"
                                                Margin="0,0,9,0">
                                            <Border.Style>
                                                <Style TargetType="{x:Type Border}">
                                                    <Setter Property="Opacity" Value="0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Value="True">
                                                            <DataTrigger.Binding>
                                                                <MultiBinding Converter="{StaticResource ReferenceEqualsMultiConverter}">
                                                                    <Binding/>
                                                                    <Binding Path="DataContext.SelectedDeviceUserPreset"
                                                                             RelativeSource="{RelativeSource AncestorType={x:Type Window}}"/>
                                                                </MultiBinding>
                                                            </DataTrigger.Binding>
                                                            <Setter Property="Opacity" Value="1"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Slot}"
                                                   Width="22"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource WolfCyanBrush}"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"/>
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource WolfTextBrush}"/>
                                            <TextBlock Text="Switch active EQ"
                                                       Style="{StaticResource DimText}"
                                                       Margin="0,1,0,0"/>
                                        </StackPanel>
                                        <controls:PhosphorIcon Grid.Column="3"
                                                               IconName="SlidersHorizontal"
                                                               IconSize="17"
                                                               IconBrush="{StaticResource WolfDimBrush}"
                                                               VerticalAlignment="Center"
                                                               Margin="10,0,0,0"/>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
